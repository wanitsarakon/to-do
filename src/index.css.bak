@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700&family=DM+Mono:wght@400;500&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

:root {
  --bg:           #F0F4FF;
  --surface:      #FFFFFF;
  --surface-glass:rgba(255,255,255,0.78);
  --border:       rgba(99,120,200,0.13);
  --border2:      rgba(99,120,200,0.22);
  --text:         #0F1729;
  --text2:        #5B6585;
  --text3:        #9BA3BE;
  --blue:         #2563EB;
  --blue2:        #1D4ED8;
  --blue3:        #3B82F6;
  --blue-bg:      #EEF3FE;
  --green:        #16A34A;  --green-bg:  #DCFCE7;
  --amber:        #D97706;  --amber-bg:  #FEF3C7;
  --red:          #DC2626;  --red-bg:    #FEE2E2;
  --purple:       #7C3AED;  --purple-bg: #EDE9FE;
  --sidebar:      258px;
  --radius:       14px;
  --radius-sm:    9px;
  --radius-lg:    20px;
  --radius-xl:    26px;
  --font:         'Inter', sans-serif;
  --font-head:    'Poppins', sans-serif;
  --mono:         'DM Mono', monospace;
  --shadow:       0 1px 3px rgba(37,99,235,.07), 0 4px 16px rgba(37,99,235,.06);
  --shadow-md:    0 4px 24px rgba(37,99,235,.10), 0 1px 4px rgba(0,0,0,.04);
  --anim:         .18s cubic-bezier(.4,0,.2,1);
}

[data-dark] {
  --bg:           #070B16;
  --surface:      #101725;
  --surface-glass:rgba(16,23,37,0.94);
  --border:       rgba(99,130,235,.20);
  --border2:      rgba(99,130,235,.34);
  --text:         #F8FAFC;
  --text2:        #D4DCEE;
  --text3:        #9AA7C2;
  --blue-bg:      #131D3A;
  --green-bg:     #11261F;
  --amber-bg:     #2B1F05;
  --red-bg:       #251112;
  --purple-bg:    #1C113C;
}

body {
  font-family: var(--font);
  background:   var(--bg);
  color:        var(--text);
  font-size:    14px;
  line-height:  1.5;
  transition:   background var(--anim), color var(--anim);
}

.app-root {
  display: flex;
  min-height: 100vh;
}

main,
.app-main {
  margin-left: var(--sidebar);
  width: calc(100% - var(--sidebar));
  padding: 32px 30px;
  min-height: 100vh;
}

.page {
  max-width: 1180px;
  width: 100%;
}

/* ── BUTTONS ── */
.btn {
  display:      inline-flex;
  align-items:  center;
  gap:          7px;
  padding:      9px 18px;
  border-radius:var(--radius-sm);
  font-size:    13px;
  font-weight:  600;
  cursor:       pointer;
  border:       none;
  font-family:  var(--font);
  transition:   all var(--anim);
}
.btn-primary {
  background:   linear-gradient(135deg,#2563EB,#3B82F6);
  color:        #fff;
  box-shadow:   0 2px 8px rgba(37,99,235,.3);
}
.btn-primary:hover  { background: linear-gradient(135deg,#1D4ED8,#2563EB); transform:translateY(-1px); box-shadow:0 4px 14px rgba(37,99,235,.35); }
.btn-primary:active { transform: scale(.97); }
.btn-ghost {
  background:   var(--surface);
  color:        var(--text2);
  border:       1px solid var(--border2);
}
.btn-ghost:hover { background:var(--blue-bg); color:var(--blue); border-color:var(--blue); }

/* ── CARD ── */
.card {
  background:        var(--surface-glass);
  backdrop-filter:   blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border:            1px solid var(--border);
  border-radius:     var(--radius);
  padding:           20px 22px;
  box-shadow:        var(--shadow);
}
.card-head {
  font-family:  var(--font-head);
  font-size:    14px;
  font-weight:  600;
  margin-bottom:18px;
  display:      flex;
  align-items:  center;
  justify-content:space-between;
  letter-spacing:-.2px;
}

/* ── TAGS ── */
.tag { font-size:11px; font-weight:600; padding:3px 9px; border-radius:99px; white-space:nowrap; }
.t-work     { background:var(--blue-bg);   color:#1D4ED8; }
.t-personal { background:var(--purple-bg); color:#6D28D9; }
.t-study    { background:var(--amber-bg);  color:#92400E; }
.t-health   { background:var(--green-bg);  color:#166534; }
.p-high     { background:var(--red-bg);    color:#B91C1C; }
.p-med      { background:var(--amber-bg);  color:#92400E; }
.p-low      { background:var(--green-bg);  color:#166534; }

/* ── FORMS ── */
.form-group  { margin-bottom:12px; }
.form-label  { font-size:11.5px; font-weight:700; color:var(--text2); display:block; margin-bottom:5px; letter-spacing:.3px; text-transform:uppercase; }
input, select, textarea {
  font-family:  var(--font);
  font-size:    13.5px;
  border:       1px solid var(--border2);
  border-radius:var(--radius-sm);
  padding:      9px 13px;
  background:   var(--surface);
  color:        var(--text);
  width:        100%;
  transition:   all var(--anim);
  outline:      none;
}
input:focus, select:focus, textarea:focus {
  border-color: var(--blue);
  box-shadow:   0 0 0 3px rgba(37,99,235,.1);
}

/* ── TOGGLE ── */
.tgl-row { display:flex; align-items:center; justify-content:space-between; padding:13px 0; border-bottom:1px solid var(--border); }
.tgl-row:last-child { border:none; }
.tgl-info p    { font-size:13.5px; font-weight:600; margin-bottom:2px; }
.tgl-info span { font-size:12px; color:var(--text3); }
.tgl {
  width:42px; height:24px; border-radius:99px;
  background:var(--border2); position:relative;
  cursor:pointer; transition:background var(--anim); flex-shrink:0;
}
.tgl.on { background:linear-gradient(135deg,#2563EB,#3B82F6); }
.tgl::after {
  content:''; position:absolute; width:18px; height:18px; border-radius:50%;
  background:#fff; top:3px; left:3px; transition:left var(--anim); box-shadow:0 1px 4px rgba(0,0,0,.2);
}
.tgl.on::after { left:21px; }

/* ── GRIDS ── */
.grid31 { display:grid; grid-template-columns:1.6fr 1fr; gap:16px; margin-bottom:16px; }
.grid2  { display:grid; grid-template-columns:1fr 1fr;   gap:16px; margin-bottom:16px; }

/* ── PROGRESS ── */
.prog-bar  { height:7px; background:var(--border2); border-radius:99px; overflow:hidden; }
.prog-fill { height:100%; border-radius:99px; transition:width .8s cubic-bezier(.4,0,.2,1); }
.pf-blue   { background:linear-gradient(90deg,#2563EB,#60A5FA); }
.pf-green  { background:linear-gradient(90deg,#16A34A,#4ADE80); }
.pf-amber  { background:linear-gradient(90deg,#D97706,#FCD34D); }
.pf-purple { background:linear-gradient(90deg,#7C3AED,#A78BFA); }

/* ── TOPBAR ── */
.topbar { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:26px; gap:12px; flex-wrap:wrap; }
.topbar h1 { font-family:var(--font-head); font-size:22px; font-weight:700; letter-spacing:-.4px; margin-bottom:3px; }
.topbar p  { font-size:13px; color:var(--text2); }

/* ── TOAST ── */
.toast {
  display:flex; align-items:center; gap:10px; padding:12px 16px;
  border-radius:var(--radius); background:var(--surface);
  border:1px solid var(--border2); box-shadow:0 8px 28px rgba(0,0,0,.12);
  font-size:13px; font-weight:500; min-width:240px; max-width:320px;
  animation: slideIn .3s cubic-bezier(.4,0,.2,1);
}
@keyframes slideIn { from { transform:translateX(120%); opacity:0; } to { transform:none; opacity:1; } }
.toast-wrapper {
  position: fixed;
  bottom: 20px;
  right: 20px;
  z-index: 999;
}
.toast-icon { width:20px; height:20px; border-radius:50%; display:grid; place-items:center; flex-shrink:0; }
.toast-success .toast-icon { background:var(--green); }
.toast-danger  .toast-icon { background:var(--red);   }
.toast-info    .toast-icon { background:var(--blue);  }

.task-row-list {
  display:grid;
  grid-template-columns: auto minmax(0, 1fr) auto auto;
  gap: 16px;
  align-items:center;
  padding: 14px 0;
  border-bottom: 1px solid rgba(37,99,235,.08);
}

.task-row-list.done {
  opacity: 0.7;
}

.task-row-list strong {
  display:block;
}

.task-row-list .task-subtitle {
  margin: 4px 0 0;
}

.task-table {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}

.table-head,
.table-row {
  display:grid;
  grid-template-columns: minmax(0, 1.8fr) 1fr 1fr 1fr 1.2fr;
  gap: 12px;
  align-items: center;
  padding: 16px 18px;
}

.table-head {
  background: rgba(37,99,235,.06);
  color: var(--blue);
  font-weight: 700;
}

.table-row {
  border-top: 1px solid rgba(37,99,235,.08);
  transition: background var(--anim);
}

.table-row:hover {
  background: rgba(37,99,235,.04);
}

.table-row.drag-over {
  background: rgba(37,99,235,.16);
}

.table-row.done {
  opacity: 0.72;
}

.chart-card {
  min-height: 240px;
}

/* ── RESPONSIVE ── */
@media(max-width:1040px) {
  .grid31, .grid2, .profile-grid { grid-template-columns:1fr; }
}
@media(max-width:720px) {
  :root { --sidebar:0px; }
  main  { margin-left:0 !important; padding:20px 16px; padding-top:64px; }
}

.hero-banner {
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
  padding: 20px 24px;
  margin-bottom: 24px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.hero-banner h1 {
  font-size: 28px;
}

.hero-banner p {
  color: var(--text3);
}

.hero-row {
  margin-bottom: 20px;
}

.hero-card {
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:20px;
  padding:26px 28px;
  background: linear-gradient(135deg,#2563EB,#7C3AED);
  border-radius: var(--radius);
  color:#fff;
  box-shadow: 0 12px 30px rgba(37,99,235,.18);
}

.hero-card h2 {
  font-size: 20px;
  margin-top: 8px;
}

.hero-badge {
  background: rgba(255,255,255,.16);
  color: #fff;
  font-size: 25px;
  font-weight: 700;
  padding: 18px 24px;
  border-radius: 18px;
}

.stats-grid .small-card {
  padding: 22px 24px;
}

.stat-value {
  font-size: 32px;
  margin: 14px 0 8px;
}

.stat-detail {
  color: var(--text3);
}

.calendar-card {
  min-height: 400px;
}

.calendar-grid {
  display:grid;
  grid-template-columns: repeat(7, 1fr);
  gap:8px;
  margin-top: 18px;
}

.calendar-day {
  display:grid;
  place-items:center;
  min-height: 50px;
  border-radius: 12px;
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text2);
}

.calendar-day.header {
  background: transparent;
  border-color: transparent;
  color: var(--text3);
  font-weight: 700;
}

.calendar-day.selected {
  background: var(--blue);
  color: #fff;
  border-color: transparent;
}

.calendar-day.has-event {
  position: relative;
}

.calendar-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--amber);
  position: absolute;
  bottom: 8px;
  right: 8px;
}

.calendar-summary {
  margin-top: 18px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}

.calendar-summary-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}

.chart-placeholder {
  min-height: 220px;
  display: grid;
  place-items: center;
  color: var(--text3);
  background: rgba(255,255,255,.08);
  border-radius: 18px;
}

.progress-block {
  display:grid;
  gap: 14px;
}

.progress-row {
  display:flex;
  justify-content:space-between;
  color: var(--text2);
  font-size: 14px;
  margin-bottom: 6px;
}

.activity-list {
  display:grid;
  gap: 14px;
}

.activity-item {
  display:flex;
  gap: 12px;
  align-items: flex-start;
}

.activity-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  margin-top: 8px;
  flex-shrink: 0;
}

.task-row-list {
  display:grid;
  grid-template-columns: auto 1fr auto auto;
  gap: 16px;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
}

.task-checkbox {
  display:flex;
  align-items:center;
  gap: 10px;
}

.task-checkbox input {
  width: 16px;
  height: 16px;
}

.task-checkbox span {
  width: 0;
  height: 0;
}

.task-subtitle {
  display:block;
  color: var(--text3);
  font-size: 13px;
  margin-top: 4px;
}

.search-row {
  display:flex;
  gap:14px;
  flex-wrap:wrap;
  align-items:center;
  margin-bottom: 18px;
}

.search-box,
.sort-select {
  padding: 12px 16px;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: var(--surface);
  font-size: 14px;
  color: var(--text);
  outline: none;
}

.search-box {
  flex:1;
  min-width:220px;
}

.sort-select {
  min-width: 180px;
  max-width: 220px;
}

.profile-hero {
  display:flex;
  justify-content:space-between;
  gap:20px;
  padding: 24px 26px;
  border-radius: var(--radius);
  background: linear-gradient(135deg,#2563EB,#7C3AED);
  color: #fff;
  margin-bottom: 24px;
  box-shadow: 0 18px 30px rgba(37,99,235,.18);
}

.profile-hero-left {
  display:flex;
  gap: 18px;
  align-items:center;
}

.profile-avatar {
  width: 72px;
  height: 72px;
  border-radius: 24px;
  display:grid;
  place-items:center;
  background: rgba(255,255,255,.18);
  font-size: 28px;
  font-weight: 700;
}

.profile-hero h2 {
  margin-bottom: 6px;
}

.profile-hero p,
.profile-hero a {
  color: rgba(255,255,255,.9);
}

.profile-stats {
  display:flex;
  gap:16px;
  align-items:center;
}

.profile-stats div {
  text-align:center;
}

.profile-stats strong {
  display:block;
  font-size: 24px;
}

.profile-grid {
  align-items:start;
}

.completion-card {
  margin-top: 16px;
}

.task-actions {
  display:flex;
  gap: 10px;
}

.btn-ghost {
  background: var(--surface);
  color: var(--text2);
  border: 1px solid var(--border2);
}

.btn-ghost:hover {
  background: var(--blue-bg);
  color: var(--blue);
}
